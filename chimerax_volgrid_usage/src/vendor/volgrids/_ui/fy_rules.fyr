!def _smif_mode
    path_in[]1.PATH
    ~folder_out[o,out]1.PATH
    ~path_traj[t,traj]1.PATH
    ~path_apbs[a,apbs]1.PATH
    ~path_chem[e,chem]1.PATH
    ~configs[c,config]*.STR
    ~box[b,box]6.FLOAT
    ~sphere[s,sphere]4+.FLOAT
    ~residues[r,residues]1+.STR
    ~nproc[n,nproc]1.INT=1
    ~pack[,pack]
!fed

@smiffer
    !use:_smif_mode
!@

@smutils
    #### Utilities useful when running smiffer
    @res_nobp
        path_in[]1.PATH
    !@
    @res_nostk
        path_in[]1.PATH
    !@
    @chemgen
        path_in[]1.PATH
        ~path_out[]1.PATH
    !@
    @sphere
        @find
            path_in[]1.PATH
            query[]1.STR
            ~path_traj[t,traj]1.PATH
            ~radius_extra[r,radius-extra]1.FLOAT=0.0
        !@
        @grid
            path_in[]1.PATH
            sphere[s,sphere]4+.FLOAT
            ~folder_out[o,out]1.PATH
            ~path_traj[t,traj]1.PATH
        !@
    !@

    #### Advanced applications of the SMIF model
    @occupancy
        !use:_smif_mode
    !@
    @pwoverlap
        path_source[]1.PATH
        path_target[]1.PATH
        path_out[]1.PATH
    !@

    #### Miscellaneous
    @box_dim
        path_in[]1.PATH
    !@
    @log_apbs
        !use:_io_1_input
    !@
!@

@apbs
    path_in[]1.PATH
    ~conv2mrc[m,mrc]
    ~keep_pqr[p,pqr]
    ~verbose[v,verbose]
!@

@vgtools
    #### Operations for reorganizing grids
    @convert
        path_in[]1.PATH
        ~folder_out[]1.PATH
        ~format[f,format]1.STR=MRC
    !@
    @pack
        paths_in[]1+.PATH
        path_out[o,out]1.PATH
    !@
    @unpack
        path_in[]1.PATH
        ~folder_out[]1.PATH
        ~format[f,format]1.STR=MRC
    !@
    @extract
        path_in[]1.PATH
    !@

    #### Operations for transforming single grids
    @fix_cmap
        !use:_io_1_input
    !@
    @rotate
        !use:_io_1_input
        ~x[x,yz]1.FLOAT=0.0
        ~y[y,xz]1.FLOAT=0.0
        ~z[z,xy]1.FLOAT=0.0
    !@
    @segment
        !use:_io_1_input
        ~isovalue[i,isovalue]1.FLOAT=0.1
        ~volume_thr[v,volume-threshold]1.INT=200
    !@

    #### Operations for combining multiple grids
    @average
        !use:_io_1_input
    !@
    @std_dev
        !use:_io_1_input
    !@
    @op
        @abs !use:_io_1_input  !@
        @add !use:_io_2_inputs !@
        @sub !use:_io_2_inputs !@
        @mul !use:_io_2_inputs !@
        @div !use:_io_2_inputs !@
        @and !use:_io_2_inputs !@
        @or  !use:_io_2_inputs !@
    !@

    #### Operations for inspecting/analyzing grids
    @summary
        path_in[]1.PATH
    !@
    @histogram
        path_in[]1.PATH
        ~path_out[o,out]1.PATH
        ~key[k,key]1.STR
    !@
    @compare
        path_0[]1.PATH
        path_1[]1.PATH
        ~threshold[t,threshold]1.FLOAT=1e-3
    !@
    @points
        path_in[]1.PATH
        points[]3+.FLOAT
    !@
!@

!def _io_1_input
    path_in[]1.PATH
    path_out[]1.PATH
!fed

!def _io_2_inputs
    path_in_0[]1.PATH
    path_in_1[]1.PATH
    path_out[]1.PATH
    ~common_box[b,common-box]
!fed
