[SELECTION_QUERY]
(protein or nucleic) and not (name H*)


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
[HYDROPHOBICITY]
;;;;;;;;; PROT
;;; WW hydrophobicity scale: negative means hydrophilic
ALA: CB=-0.17
ARG: CB,CG,CD,NE,CZ,NH1,NH2=-0.81
ASN: CB,CG,OD1,ND2=-0.42
ASP: CB,CG,OD1,OD2=-1.23
CYS: CB,SG=0.24
GLN: CB,CG,CD,OE1,NE2=-0.58
GLU: CB,CG,CD,OE1,OE2=-2.02
GLY: ;=-0.01
HIS: CB,CG,ND1,CD2,CE1,NE2=-0.96
ILE: CB,CG1,CG2,CD1=0.31
LEU: CB,CG,CD1,CD2=0.56
LYS: CB,CG,CD,CE,NZ=-0.99
MET: CB,CG,SD,CE=0.23
PHE: CB,CG,CD1,CD2,CE1,CE2,CZ=1.13
PRO: CB,CG,CD=-0.45
SER: CB,OG=-0.13
THR: CB,OG1,CG2=-0.14
TRP: CB,CG,CD1,CD2,NE1,CE2,CE3,CZ2,CZ3,CH2=1.85
TYR: CB,CG,CD1,CD2,CE1,CE2,CZ,OH=0.94
VAL: CB,CG1,CG2=-0.07

;;;;;;;;; RNA
;;; phosphate ~ GLU (-2.02) ; sugar ~ SER (-0.13)
;;; URA ~ PHE (1.13); CYT ~ PHE (1.13); ADE ~ TRP (1.85); GUA ~ TRP (1.85)
U: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O2',O4'=-0.13   N1,C2,N3,C4,C5,C6,O2,O4=1.13
C: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O2',O4'=-0.13   N1,C2,N3,C4,C5,C6,O2,N4=1.13
A: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O2',O4'=-0.13   N1,C2,N3,C4,C5,C6,N7,C8,N9,N6=1.85
G: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O2',O4'=-0.13   N1,C2,N3,C4,C5,C6,N7,C8,N9,N2,O6=1.85

;;;;;;;;; DNA
;;; phosphate ~ GLU (-2.02) ; sugar ~ SER (-0.13)
;;; THM ~ PHE (1.13); CYT ~ PHE (1.13); ADE ~ TRP (1.85); GUA ~ TRP (1.85)
DT: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O4'=-0.13   N1,C2,N3,C4,C5,C6,O2,O4,C7=1.13
DC: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O4'=-0.13   N1,C2,N3,C4,C5,C6,O2,N4=1.13
DA: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O4'=-0.13   N1,C2,N3,C4,C5,C6,N7,C8,N9,N6=1.85
DG: O5',P,OP1,OP2,O3'=-2.02   C1',C2',C3',C4',C5',O4'=-0.13   N1,C2,N3,C4,C5,C6,N7,C8,N9,N2,O6=1.85


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
[STACKING]
;;;;;;;;; PROT
ARG: CZ-NE-NH1-NH2
HIS: CD2-CE1-CG-ND1-NE2
PHE: CD1-CD2-CE1-CE2-CG-CZ
TRP: CD1-CD2-CE2-CE3-CG-CH2-CZ2-CZ3-NE1
TYR: CD1-CD2-CE1-CE2-CG-CZ

;;;;;;;;; RNA
U: N1-C2-N3-C4-C5-C6
C: N1-C2-N3-C4-C5-C6
A: N1-C2-N3-C4-C5-C6-N7-C8-N9
G: N1-C2-N3-C4-C5-C6-N7-C8-N9
; A: N1-C2-N3-C4-C5-C6   C4-C5-N7-C8-N9 ;; alternative 2-ring version
; G: N1-C2-N3-C4-C5-C6   C4-C5-N7-C8-N9

;;;;;;;;; DNA
DT: N1-C2-N3-C4-C5-C6
DC: N1-C2-N3-C4-C5-C6
DA: N1-C2-N3-C4-C5-C6-N7-C8-N9
DG: N1-C2-N3-C4-C5-C6-N7-C8-N9
; DA: N1-C2-N3-C4-C5-C6   C4-C5-N7-C8-N9 ;; alternative 2-ring version
; DG: N1-C2-N3-C4-C5-C6   C4-C5-N7-C8-N9


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
[HBACCEPTORS]
;;;;;;;;; PROT
;;; https://chemistry.stackexchange.com/questions/42085/can-an-amide-nitrogen-be-a-hydrogen-bond-acceptor
ALA: O=C->O
ARG: O=C->O
ASN: O=C->O OD1=CG->OD1
ASP: O=C->O OD1=CG->OD1 OD2=CG->OD2
CYS: O=C->O SG=CB->SG ; https://link.springer.com/chapter/10.1007/978-3-319-14163-3_2
GLU: O=C->O OE1=CD->OE1 OE2=CD->OE2
GLN: O=C->O OE1=CD->OE1
GLY: O=C->O
HIS: O=C->O ND1=CE1.CG->ND1
ILE: O=C->O
LEU: O=C->O
LYS: O=C->O
MET: O=C->O SD=CG->SD
PHE: O=C->O
PRO: O=C->O
SER: O=C->O OG=CB->OG
THR: O=C->O OG1=CB->OG1
TRP: O=C->O
TYR: O=C->O OH=CZ->OH
VAL: O=C->O

;;;;;;;;; RNA
;;; https://onlinelibrary.wiley.com/iucr/itc/Fa/ch22o2v0001/sec22o2o4.pdf
U: O2'=C2'->O2' O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 O2=C2->O2 O4=C4->O4
C: O2'=C2'->O2' O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 O2=C2->O2 N3=C2.C4->N3
A: O2'=C2'->O2' O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 N1=C2.C6->N1 N3=C2.C4->N3 N7=C5.C8->N7
G: O2'=C2'->O2' O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 N3=C2.C4->N3 N7=C5.C8->N7 O6=C6->O6

;;;;;;;;; DNA
DT: O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 O2=C2->O2 O4=C4->O4
DC: O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 O2=C2->O2 N3=C2.C4->N3
DA: O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 N1=C2.C6->N1 N3=C2.C4->N3 N7=C5.C8->N7
DG: O3'=C3'.P->O3' O4'=C1'.C4'->O4' O5'=C5'.P->O5' OP1=P->OP1 OP2=P->OP2 N3=C2.C4->N3 N7=C5.C8->N7 O6=C6->O6


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;; PROT
[HBDONORS]
ALA: N=C.CA->N ; in peptide bonds it's hbdonors_fixed, that's handled internally in the code
ARG: N=C.CA->N NE=CD.CZ->NE! NH1=NH2->CZ! NH1=NE->CZ! NH2=NH1->CZ! NH2=NE->CZ!
ASN: N=C.CA->N ND2=OD1->CG! ND2=CB->CG!
ASP: N=C.CA->N
CYS: N=C.CA->N SG=CB->SG
GLU: N=C.CA->N
GLN: N=C.CA->N NE2=OE1->CD! NE2=CG->CD!
GLY: N=C.CA->N
HIS: N=C.CA->N NE2=CD2.CE1->NE2!
ILE: N=C.CA->N
LEU: N=C.CA->N
LYS: N=C.CA->N NZ=CE->NZ
MET: N=C.CA->N
PHE: N=C.CA->N
PRO: N=CA.CD->N!
SER: N=C.CA->N OG=CB->OG
THR: N=C.CA->N OG1=CB->OG1
TRP: N=C.CA->N NE1=CD1.CE2->NE1!
TYR: N=C.CA->N OH=CZ->OH
VAL: N=C.CA->N

;;;;;;;;; RNA
;;; https://pubs.acs.org/doi/10.1021/j100645a012
U: O2'=C2'->O2' O3'=C3'->O3' O5'=C5'->O5' N3=C6->N3!
C: O2'=C2'->O2' O3'=C3'->O3' O5'=C5'->O5' N4=C5->C4! N4=N3->C4!
A: O2'=C2'->O2' O3'=C3'->O3' O5'=C5'->O5' N6=C5->C6! N6=N1->C6!
G: O2'=C2'->O2' O3'=C3'->O3' O5'=C5'->O5' N1=C4->N1! N2=N1->C2! N2=N3->C2!

;;;;;;;;; DNA
DT: O3'=C3'->O3' O5'=C5'->O5' N3=C6->N3!
DC: O3'=C3'->O3' O5'=C5'->O5' N4=C5->C4! N4=N3->C4!
DA: O3'=C3'->O3' O5'=C5'->O5' N6=C5->C6! N6=N1->C6!
DG: O3'=C3'->O3' O5'=C5'->O5' N1=C4->N1! N2=N1->C2! N2=N3->C2!


